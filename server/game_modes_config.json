{
  "description": "Configuración de modos de juego. Cada modo define qué canciones se usan mediante filtros.",
  "modes": {
    "clasico": {
      "label": "Clásico",
      "description": "Todas las canciones disponibles en el catálogo",
      "filter": "all"
    },
    "fuego_cruzado": {
      "label": "Fuego Cruzado",
      "description": "Solo canciones con género conocido (excluye 'unknown')",
      "filter": "has_genre"
    },
    "solo_baladas": {
      "label": "Noche de Baladas",
      "description": "Solo baladas y pop romántico",
      "filter": "genre",
      "genres": ["balada", "pop"]
    },
    "puro_reggaeton": {
      "label": "Puro Perreo",
      "description": "Solo reggaeton y ritmos urbanos",
      "filter": "genre",
      "genres": ["reggaeton"]
    },
    "rockola": {
      "label": "Rockola",
      "description": "Rock, pop rock y baladas rock",
      "filter": "genre",
      "genres": ["rock", "pop"]
    },
    "mexicanada": {
      "label": "Mexicanada",
      "description": "Banda, ranchera y cumbia",
      "filter": "genre",
      "genres": ["banda", "ranchera", "cumbia"]
    },
    "electronico": {
      "label": "Electro Mix",
      "description": "Electrónica y dance",
      "filter": "genre",
      "genres": ["electronica", "pop"]
    }
  }
}
