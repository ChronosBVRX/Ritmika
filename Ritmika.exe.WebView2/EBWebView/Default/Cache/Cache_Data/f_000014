function buildRouletteWheel() {
  const wheel = document.getElementById('roulette-wheel');
  wheel.innerHTML = '';
  const players   = state.players;
  const n         = players.length;
  const cx        = 210, cy = 210, r = 190;
  const sliceAngle = (2 * Math.PI) / n;

  const SLICE_COLORS = ['#ec4899','#22d3ee','#a855f7','#facc15','#f97316','#22c55e','#3b82f6','#06b6d4'];

  players.forEach((p, i) => {
    const startA = i * sliceAngle - Math.PI / 2;
    const endA   = startA + sliceAngle;
    const x1 = cx + r * Math.cos(startA), y1 = cy + r * Math.sin(startA);
    const x2 = cx + r * Math.cos(endA),   y2 = cy + r * Math.sin(endA);
    const lg = n === 1 ? '1' : '0';

    // Slice
    const path = document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d', `M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${lg},1 ${x2},${y2} Z`);
    path.setAttribute('fill', SLICE_COLORS[i % SLICE_COLORS.length]);
    path.setAttribute('stroke', '#0f172a');
    path.setAttribute('stroke-width', '2');
    path.style.opacity = '0.85';
    wheel.appendChild(path);

    // Label
    const midA = startA + sliceAngle / 2;
    const lx = cx + (r * 0.62) * Math.cos(midA);
    const ly = cy + (r * 0.62) * Math.sin(midA);
    const deg = (midA * 180 / Math.PI) + 90;

    const av = getAvatar(p.avatarId);
    // Emoji
    const emojiText = document.createElementNS('http://www.w3.org/2000/svg','text');
    emojiText.setAttribute('x', lx); emojiText.setAttribute('y', ly - 12);
    emojiText.setAttribute('text-anchor','middle'); emojiText.setAttribute('dominant-baseline','middle');
    emojiText.setAttribute('font-size', n > 6 ? '16' : '20');
    emojiText.setAttribute('transform', `rotate(${deg},${lx},${ly})`);
    emojiText.textContent = av.emoji;
    wheel.appendChild(emojiText);

    // Name
    const nameText = document.createElementNS('http://www.w3.org/2000/svg','text');
    nameText.setAttribute('x', lx); nameText.setAttribute('y', ly + 10);
    nameText.setAttribute('text-anchor','middle'); nameText.setAttribute('dominant-baseline','middle');
    nameText.setAttribute('font-size', n > 6 ? '10' : '12');
    nameText.setAttribute('font-weight','900'); nameText.setAttribute('fill','white');
    nameText.setAttribute('transform', `rotate(${deg},${lx},${ly})`);
    nameText.textContent = p.name.slice(0, 8);
    wheel.appendChild(nameText);
  });
}

document.getElementById('spin-btn').addEventListener('click', spinRoulette);

function spinRoulette() {
  if (isSpinning) return;
  isSpinning = true;
  document.getElementById('spin-btn').disabled = true;
  document.getElementById('selected-player-banner').style.opacity = '0';

  // Pick winner deterministically
  const winnerIdx = state.currentSingerIdx % state.players.length;
  const winner    = state.singerQueue[winnerIdx] || state.players[winnerIdx];
  const n         = state.players.length;

  // Calculate angle to land on winner's slice
  const sliceDeg   = 360 / n;
  const targetSlice = state.players.findIndex(p => p.socketId === winner.socketId);
  // Arrow is at top (270° in SVG terms); we want that slice under arrow
  const targetAngle = 360 * 6 + (360 - targetSlice * sliceDeg - sliceDeg / 2);

  anime({
    targets: '#roulette-wheel',
    rotate:  [rouletteAngle, rouletteAngle + targetAngle],
    duration: 4500,
    easing: 'cubicBezier(0.17, 0.67, 0.12, 0.99)',
    update: (anim) => {
      // Tick sound effect via slight wheel blur at high speed
    },
    complete: () => {
      rouletteAngle = (rouletteAngle + targetAngle) % 360;
      isSpinning = false;
      showRouletteResult(winner);
    },
  });

  // Axolo excitement during spin
  axoloSay('¡El destino decide quién sufre primero! 🎰🔥', 'roulette_spin.wav');
}

