anime({ targets:'#axolo-container', rotate:[-1.5,1.5], duration:4000, easing:'easeInOutSine', direction:'alternate', loop:true });

let currentAxoloAudio = null;
let mouthAnimation = null;

function startMouthAnimation() {
  const mouth = document.getElementById('axolo-mouth-css');
  mouth.classList.add('open');
  if (mouthAnimation) {
    mouthAnimation.pause();
  }
  mouthAnimation = anime({
    targets: '#axolo-mouth-css',
    scaleY: [1, 2.5, 1],
    duration: 160,
    loop: true,
    direction: 'alternate',
    easing: 'easeInOutSine'
  });
}

function stopMouthAnimation() {
  if (mouthAnimation) {
    mouthAnimation.pause();
    mouthAnimation = null;
  }
  const mouth = document.getElementById('axolo-mouth-css');
  mouth.classList.remove('open');
  anime({
    targets: '#axolo-mouth-css',
    scaleY: 1,
    duration: 100,
    easing: 'easeOutSine'
  });
}

function axoloTalk(duration = 2000) {
  const mouth = document.getElementById('axolo-mouth-css');
  if (mouthInterval) clearInterval(mouthInterval);
  let toggle = true;
  mouth.classList.add('open');
  mouthInterval = setInterval(() => { toggle = !toggle; mouth.classList.toggle('open', toggle); }, 160);
  setTimeout(() => { if(mouthInterval){clearInterval(mouthInterval); mouthInterval=null;} mouth.classList.remove('open'); }, duration);
}

async function hacerHablarAlAxolo(texto, audioFileOrMood = 'neutral') {
  const isAudioFile = typeof audioFileOrMood === 'string' &&
                      (audioFileOrMood.endsWith('.wav') || audioFileOrMood.endsWith('.mp3'));

  try {
    if (currentAxoloAudio) {
      currentAxoloAudio.pause();
    }
    stopMouthAnimation();

    if (isAudioFile) {
      const cleanName = audioFileOrMood.replace(/\.(wav|mp3)$/i, '') + '.mp3';
      const audioUrl = `/assets/audio/${cleanName}`;
      currentAxoloAudio = new Audio(audioUrl);
      
      currentAxoloAudio.addEventListener('play', () => {
        startMouthAnimation();
      });
      
      currentAxoloAudio.addEventListener('ended', () => {
        stopMouthAnimation();
      });
      
      currentAxoloAudio.addEventListener('pause', () => {
        stopMouthAnimation();
      });

      await currentAxoloAudio.play();
      return true;
    } else {
      console.warn(`[Voice] No audio asset mapped for: "${texto}" (received: ${audioFileOrMood}). Staying silent.`);
      return false;
    }
  } catch (err) {
    console.error('[Voice] Error playing ElevenLabs audio asset:', err);
    return false;
  }
}

async function axoloSay(text, moodOrDuration = 'neutral', duration = 4000) {
  let audioFile = 'neutral';
  let bubbleDur = duration;

  if (typeof moodOrDuration === 'number') {
    bubbleDur = moodOrDuration;
  } else if (typeof moodOrDuration === 'string') {
    audioFile = moodOrDuration;
  }

  axoloBubble.textContent = text;
  if (axoloSpeechTimeout) clearTimeout(axoloSpeechTimeout);
  anime({ targets: axoloBubble, opacity:[0,1], scale:[0.8,1], translateY:[8,0], duration:350, easing:'easeOutBack' });

  // Call voice player
  const spokeWithAudio = await hacerHablarAlAxolo(text, audioFile);

  const hideBubble = () => {
    anime({ targets: axoloBubble, opacity:[1,0], scale:[1,0.9], duration:300, easing:'easeInCubic' });
  };

  if (spokeWithAudio && currentAxoloAudio) {
    currentAxoloAudio.addEventListener('ended', hideBubble, { once: true });
    axoloSpeechTimeout = setTimeout(hideBubble, 15000); // safety timeout
  } else {
    // If silent, fallback to manual mouth toggle for the bubble duration
    axoloTalk(Math.min(bubbleDur - 500, 4000));
    axoloSpeechTimeout = setTimeout(hideBubble, bubbleDur);
  }
}


