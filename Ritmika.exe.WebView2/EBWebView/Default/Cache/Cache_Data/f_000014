        <span class="font-black text-xs" style="color:${scoreColor};">${p.score||0}</span>
        <span class="text-[9px] text-slate-500"> pts</span>
      </div>
    `;
    sb.appendChild(row);
    setTimeout(() => {
      anime({ targets: row, opacity:[0,1], translateX:[-20,0], duration:400, easing:'easeOutCubic' });
    }, 1800 + i * 100);
  });

  // Notify phones
  socket.emit('tv:broadcast', {
    roomCode: state.roomCode,
    event: 'GAME_OVER',
    data: { results: sorted.map((p,i) => ({
      socketId: p.socketId, name: p.name, score: p.score,
      award: i===0 ? '👑 Rey del Palenque' : p===sorted[sorted.length-1] ? '🐓 Gallo Supremo' : '🎤 Participante'
    })) },
  });

  // Climax speech sequential chain
  const winner = sorted[0];
  const podiumScript = `¡Y así termina la noche más épica del año! Con ${winner?.score || 0} puntos, el ganador es... ¡${winner?.name || 'alguien misterioso'}! ¡El Rey del Palenque ha sido coronado! ¡Gracias banda por esta noche de gloria, carrilla y algún que otro tomate! ¡Hasta la próxima fiesta!`;
  
  // First, Tío Axolo congratulates the winner
  axoloSay(`¡Felicidades al ganador, te la rifaste de veras! 🏆`, 'final_victory.mp3');

  // Then speak the climax when final_victory finishes
  setTimeout(() => {
    if (currentAxoloAudio) {
      currentAxoloAudio.addEventListener('ended', () => {
        axoloSay(podiumScript, 'podium_climax.mp3');
      }, { once: true });
    }
  }, 500); // short delay to ensure Audio element has been initialized

  // Celebration emojis burst
  ['🎉','🎊','🏆','⭐','🔥','🎵','💫','🌟'].forEach((e, i) =>
    setTimeout(() => floatEmoji(e), i * 150)
  );
}

